<Window x:Class="OOP_NW_Airbnb.ContactChat"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OOP_NW_Airbnb"
        mc:Ignorable="d"
        Title="ContactChat" Height="700" Width="900"
        WindowStartupLocation="CenterScreen">

    <Grid>
         <!---Rows-->
 <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
 </Grid.RowDefinitions>

 <!---Cols-->
 <Grid.ColumnDefinitions>
     <ColumnDefinition Width="3*"/>
     <ColumnDefinition Width="7*"/>
 </Grid.ColumnDefinitions>

<!--SECTION: Left Side-->
<Border Grid.Row="0" Grid.Column="0" Background="LightGray" Padding="10">
    <TextBlock Text="Quick Navigation"/>
</Border>
        
<!--SECTION: Right Side-->
        <Border Grid.Row="0" Grid.Column="1" Background="White" Padding="10">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <!-- Chat messages -->
                    <RowDefinition Height="Auto"/>
                    <!-- Input box -->
                </Grid.RowDefinitions>

                <!-- Chat display area -->
                <TextBlock Text="Chat Panel" Grid.Row="0" VerticalAlignment="Top"/>

                <!-- Input box -->
                <Grid Grid.Row="1" Margin="0,10,0,0">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Text Input -->
                        <TextBox Name="txtChatInput" Height="30" Margin="0,0,10,0" Grid.Column="0"/>

                        <!-- Send Button -->
                        <Button Name="btnChatInput" Content="Send" Width="80" Grid.Column="1"/>

                </Grid>

            </Grid>

        </Border>

    </Grid>
</Window>
