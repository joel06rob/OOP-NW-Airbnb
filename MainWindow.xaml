<Window x:Class="OOP_NW_Airbnb.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OOP_NW_Airbnb"
        mc:Ignorable="d"
        Title="MainWindow" Height="700" Width="900"
        WindowStartupLocation="CenterScreen"
        >
    
    <!--Background Grid-->
    <Grid>

        <!---Rows-->
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>

        <!---Cols-->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="7*"/>
        </Grid.ColumnDefinitions>

        <!--SECTION: Header-->
        <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Background="LightGray" Padding="10">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="AIR BNB NW" FontSize="40" VerticalAlignment="Center" Margin="0,0,0,0"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Name="btnLogin" Content="Login" Width="100" Height="50" Margin="10"/>
                    <Button Name="btnContact"  Content="Contact" Width="100" Height="50" Margin="10"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!--SECTION: Left Side-->
        <Border Grid.Row="1" Grid.Column="0" Background="LightGray" Padding="10">
            <TextBlock Text="Quick Navigation"/>
        </Border>

        <!--SECTION: Right Side-->
        <Border Grid.Row="1" Grid.Column="1" Background="#ffffff" Padding="10">
            <TextBlock Text="Main Section"/>
        </Border>

    </Grid>
</Window>
